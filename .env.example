# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

DATABASE_URL="mysql://user:password@localhost:3306/database_name"

JWT_SECRET="your-jwt-secret-here"

API_KEY_DUITKU="your-duitku-api-key"
MERCH_ID="your-merchant-id"
DUITKU_CALLBACK_URL="https://your-domain.com/api/v1/callback/payment/duitku"
DUITKU_RETURN_URL="https://your-domain.com"

MIDTRANS_MERCHANT_ID="your-midtrans-merchant-id"
MIDTRANS_CLIENT_KEY="your-midtrans-client-key"
MIDTRANS_SERVER_KEY="your-midtrans-server-key"
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_FINISH_URL="https://your-domain.com"

R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_PUBLIC_URL="https://your-public-asset-domain/"

GITHUB_WEBHOOK_SECRET="your-github-webhook-secret"

PORT=3000

{
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "plugins/*": ["src/plugins/*"],
      "services/*": ["src/services/*"],
      "models/*": ["src/models/*"],
      "utils/*": ["src/utils/*"],
      "schemas/*": ["src/schemas/*"]
    },

    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "esModuleInterop": true,
    "strict": true,
    "types": ["node"],

    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src", "types"]
}

